// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ──────────────────────────────────────────────

enum BusinessType {
  CONTRACTOR
  RESTAURANT
  THERAPIST
  CONSULTANT
  PHOTOGRAPHER
  LOCAL_SERVICE
}

enum SiteRequestStatus {
  DRAFT
  QUEUED
  GENERATING
  VALIDATING
  GENERATED
  DEPLOYING
  READY
  FAILED
}

enum AssetType {
  LOGO
  HERO_IMAGE
  GALLERY_IMAGE
  GENERAL
}

enum DomainStatus {
  PENDING_VERIFICATION
  VERIFIED
  ACTIVE
  FAILED
}

// ─── Models ─────────────────────────────────────────────

model User {
  id            String         @id @default(cuid())
  email         String         @unique
  name          String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  siteRequests  SiteRequest[]
  uploadedAssets UploadedAsset[]

  @@index([email])
}

model SiteRequest {
  id               String            @id @default(cuid())
  userId           String
  user             User              @relation(fields: [userId], references: [id])

  // Business brief fields
  businessName     String
  businessType     BusinessType
  location         String?
  primaryGoal      String
  services         String[]
  about            String
  differentiators  String[]
  contactEmail     String
  contactPhone     String?
  colorPreference  String?
  fontPreference   String?
  siteVibe         String?

  // Lifecycle
  status           SiteRequestStatus @default(DRAFT)
  errorMessage     String?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  // Relations
  uploadedAssets   UploadedAsset[]
  generatedSite    GeneratedSite?
  deployment       Deployment?

  @@index([userId])
  @@index([status])
}

model UploadedAsset {
  id            String       @id @default(cuid())
  userId        String
  user          User         @relation(fields: [userId], references: [id])
  siteRequestId String?
  siteRequest   SiteRequest? @relation(fields: [siteRequestId], references: [id])

  fileName      String
  fileSize      Int
  mimeType      String
  assetType     AssetType    @default(GENERAL)
  storageKey    String       // S3 key or storage path
  publicUrl     String?      // CDN URL after processing

  createdAt     DateTime     @default(now())

  @@index([siteRequestId])
  @@index([userId])
}

model GeneratedSite {
  id              String      @id @default(cuid())
  siteRequestId   String      @unique
  siteRequest     SiteRequest @relation(fields: [siteRequestId], references: [id])

  // What Claude returned
  generatedContent Json      // The full structured content JSON
  templateId       String    // Which template was used
  themeTokens      Json      // Resolved theme tokens

  // Assembly output
  fileManifest     Json?     // Map of filepath -> content hash
  assembledAt      DateTime?

  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
}

model Deployment {
  id              String            @id @default(cuid())
  siteRequestId   String            @unique
  siteRequest     SiteRequest       @relation(fields: [siteRequestId], references: [id])

  vercelDeploymentId  String?       // Vercel's deployment ID
  vercelProjectId     String?       // Vercel project this was deployed to
  previewUrl          String?       // The live preview URL
  deploymentUrl       String?       // The specific deployment URL

  status          SiteRequestStatus @default(QUEUED)
  errorMessage    String?
  deployedAt      DateTime?

  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  domainConnection DomainConnection?

  @@index([vercelDeploymentId])
}

model DomainConnection {
  id              String        @id @default(cuid())
  deploymentId    String        @unique
  deployment      Deployment    @relation(fields: [deploymentId], references: [id])

  domain          String
  status          DomainStatus  @default(PENDING_VERIFICATION)

  // DNS instructions for user
  requiredRecords Json?         // Array of { type, name, value }
  verifiedAt      DateTime?

  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@index([domain])
}
